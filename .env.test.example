# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# Database (used by docker-compose postgres_test and tests/conftest.py)
TEST_POSTGRES_USER=mindflow_test
TEST_POSTGRES_PASSWORD=mindflow_test
TEST_POSTGRES_DB=mindflow_test
TEST_POSTGRES_HOST=localhost
TEST_POSTGRES_PORT=5433
# Optional explicit test DB URL override:
# TEST_POSTGRES_URL=postgresql+asyncpg://mindflow_test:mindflow_test@localhost:5433/mindflow_test

# API
API_PREFIX=/api

# Local file storage
STORAGE_ROOT=storage

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated, no spaces)
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
