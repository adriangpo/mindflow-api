# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# Database (used by docker-compose postgres_test and tests/conftest.py)
TEST_POSTGRES_USER=mindflow_test
TEST_POSTGRES_PASSWORD=mindflow_test
TEST_POSTGRES_DB=mindflow_test
TEST_POSTGRES_HOST=localhost
TEST_POSTGRES_PORT=5433
# Optional explicit test DB URL override:
# TEST_POSTGRES_URL=postgresql+asyncpg://mindflow_test:mindflow_test@localhost:5433/mindflow_test

# API
API_PREFIX=/api

# Redis
REDIS_URL=redis://localhost:6380/0
TEST_REDIS_URL=redis://localhost:6380/0

# Local file storage
STORAGE_ROOT=storage

# Exports
EXPORT_WORKER_ENABLED=false
EXPORT_WORKER_BLOCK_MS=1000
EXPORT_WORKER_CLAIM_IDLE_MS=30000
EXPORT_SSE_KEEPALIVE_SECONDS=15

# Notifications
NOTIFICATION_PROVIDER=stub
NOTIFICATION_BACKGROUND_DISPATCH_ENABLED=false
NOTIFICATION_DISPATCH_INTERVAL_SECONDS=60
NOTIFICATION_DELIVERY_BLOCK_MS=1000
NOTIFICATION_DELIVERY_CLAIM_IDLE_MS=30000
NOTIFICATION_DEFAULT_COUNTRY_CODE=+55
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM_NUMBER=

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated, no spaces)
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
