# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
PUBLIC_BASE_URL=http://localhost:8000

# Database
POSTGRES_USER=mindflow
POSTGRES_PASSWORD=mindflow
POSTGRES_DB=mindflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional: full DB URL override.
# - Local uv run: used directly by app settings.
# - Docker API service: used when set; otherwise compose builds URL from POSTGRES_USER/PASSWORD/HOST/DB (internal port 5432).
# POSTGRES_URL=postgresql+asyncpg://mindflow:mindflow@localhost:5432/mindflow

# Docker
API_PORT=8000

# API
API_PREFIX=/api

# Redis
REDIS_URL=redis://redis:6379/0
JOB_DISPATCH_MODE=redis_worker

# QStash
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Storage
STORAGE_BACKEND=local
STORAGE_ROOT=storage
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto

# Exports
EXPORT_WORKER_ENABLED=true
EXPORT_WORKER_BLOCK_MS=1000
EXPORT_WORKER_CLAIM_IDLE_MS=30000
EXPORT_SSE_KEEPALIVE_SECONDS=15
EXPORT_JOB_TTL_SECONDS=86400
EXPORT_EVENT_STREAM_TTL_SECONDS=3600
EXPORT_EVENT_STREAM_MAXLEN=200

# Notifications
NOTIFICATION_PROVIDER=auto
NOTIFICATION_BACKGROUND_DISPATCH_ENABLED=true
NOTIFICATION_DISPATCH_INTERVAL_SECONDS=60
NOTIFICATION_DELIVERY_BLOCK_MS=1000
NOTIFICATION_DELIVERY_CLAIM_IDLE_MS=30000
NOTIFICATION_DEFAULT_COUNTRY_CODE=+55
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sender number or sandbox sender. Accepts `+14155238886` or `whatsapp:+14155238886`.
TWILIO_WHATSAPP_FROM_NUMBER=

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated, no spaces)
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
