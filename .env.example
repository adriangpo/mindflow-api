# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# Database
POSTGRES_USER=mindflow
POSTGRES_PASSWORD=mindflow
POSTGRES_DB=mindflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional: full DB URL override.
# - Local uv run: used directly by app settings.
# - Docker API service: used when set; otherwise compose builds URL from POSTGRES_USER/PASSWORD/HOST/DB (internal port 5432).
# POSTGRES_URL=postgresql+asyncpg://mindflow:mindflow@localhost:5432/mindflow

# Docker
API_PORT=8000

# API
API_PREFIX=/api

# Local file storage
STORAGE_ROOT=storage

# Notifications
NOTIFICATION_PROVIDER=auto
NOTIFICATION_BACKGROUND_DISPATCH_ENABLED=true
NOTIFICATION_DISPATCH_INTERVAL_SECONDS=60
NOTIFICATION_DEFAULT_COUNTRY_CODE=+55
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio WhatsApp sender number or sandbox sender. Accepts `+14155238886` or `whatsapp:+14155238886`.
TWILIO_WHATSAPP_FROM_NUMBER=

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated, no spaces)
CORS_ALLOW_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
